    results: dict[str, Any] = {}
    fleet_status = load_fleet_status().get("hosts", {})

    for name, node in fleet_view().items():
        ok, reason = await ping_worker(node["base_url"])
        installed_models: list[str] = []
        if ok:
            try:
                installed_models = await list_worker_models(node["base_url"])
            except Exception:
                installed_models = []

        status = fleet_status.get(name, {})
        results[name] = {
            "ok": ok,
            "reason": reason,
            "base_url": node["base_url"],
            "primary_role": node["primary_role"],
            "secondary_roles": node["secondary_roles"],
            "gpu_count": node["gpu_count"],
            "gpu_free_mb_max": status.get("gpu_free_mb_max"),
            "gpu_vram_total_mb_max": status.get("gpu_vram_total_mb_max"),
            "load_1": status.get("load_1"),
            "running_jobs": worker_running_jobs(name, status),
            "running_gpu_jobs": ACTIVE_GPU_REQUESTS.get(name, {}),
            "installed_models": installed_models,
            "eligible": status.get("eligible", False),
            "quarantined": status.get("quarantined", False),
            "alerts": status.get("alerts", []),
            "policy": WORKER_POLICY.get(name, {}),
        }

    return results


@app.post("/fleet/register")
def register(node: FleetNode) -> dict[str, Any]:
    payload = node.model_dump()
    if not payload.get("primary_role"):
        payload["primary_role"] = payload["role"]
    if payload.get("secondary_roles") is None:
        payload["secondary_roles"] = []

    FLEET[node.name] = payload
    save_fleet()

    return {
        "ok": True,
        "registered": node.name,
        "fleet_size": len(FLEET),
        "node": normalize_node(node.name, payload),
    }


@app.post("/fleet/remove/{name}")
def remove_worker(name: str) -> dict[str, Any]:
    if name not in FLEET:
        raise HTTPException(status_code=404, detail=f"worker not found: {name}")
    removed = FLEET.pop(name)
    save_fleet()
    return {"ok": True, "removed": name, "node": removed}


@app.post("/fleet/disable/{name}")
def disable_worker(name: str) -> dict[str, Any]:
    if name not in FLEET:
        raise HTTPException(status_code=404, detail=f"worker not found: {name}")
    FLEET[name]["enabled"] = False
    save_fleet()
    return {"ok": True, "disabled": name, "node": normalize_node(name, FLEET[name])}


@app.post("/fleet/enable/{name}")
def enable_worker(name: str) -> dict[str, Any]:
    if name not in FLEET:
        raise HTTPException(status_code=404, detail=f"worker not found: {name}")
    FLEET[name]["enabled"] = True
    save_fleet()
    return {"ok": True, "enabled": name, "node": normalize_node(name, FLEET[name])}


@app.post("/exec", response_model=ExecResult)
async def exec_route(req: ExecRequest) -> ExecResult:
    node, chosen_model, gpu_lane, gpu_label = await choose_worker_and_model(
        role=req.role,
        requested_model=req.model if not req.auto_model else None,
        forced_worker=req.worker,
        forced_gpu_lane=req.gpu_lane,
        allow_fallback=req.allow_fallback,
    )

    worker_name = node["name"]
    increment_active(worker_name, gpu_lane)

    data: dict[str, Any] = {}
    response_text = ""
    try:
        if req.role == "utility" and chosen_model in EMBED_MODELS:
            data = await call_ollama_embed(node["base_url"], req, chosen_model)
            response_text = f"Embedding request completed with model {chosen_model}. Vector count: {len(data.get('embeddings', []))}"
        else:
            data = await call_ollama_generate(node["base_url"], req, chosen_model)
            response_text = data.get("response", "")
    finally:
        decrement_active(worker_name, gpu_lane)

    entry = {
        "ts": int(time.time()),
        "worker": worker_name,
        "worker_url": node["base_url"],
        "gpu_lane": gpu_lane,
        "gpu_label": gpu_label,
        "role_requested": req.role,
        "model_requested": req.model,
        "model_used": chosen_model,
        "prompt_chars": len(req.prompt),
        "response_chars": len(response_text),
        "done": data.get("done"),
        "total_duration": data.get("total_duration"),
        "load_duration": data.get("load_duration"),
        "prompt_eval_count": data.get("prompt_eval_count"),
        "eval_count": data.get("eval_count"),
    }
    append_exec_log(entry)

    return ExecResult(
        ok=True,
        worker=worker_name,
        worker_url=node["base_url"],
        gpu_lane=gpu_lane,
        gpu_label=gpu_label,
        role_requested=req.role,
        model=chosen_model,
        response=response_text,
        raw=data,
    )
