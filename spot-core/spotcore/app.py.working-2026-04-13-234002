def save_fleet() -> None:
    with FLEET_FILE.open("w", encoding="utf-8") as f:
        json.dump(FLEET, f, indent=2, sort_keys=True)



def load_node(name: str) -> dict[str, Any]:
    node = FLEET.get(name)
    if not node:
        raise HTTPException(status_code=404, detail=f"worker not found: {name}")
    if not node.get("enabled", True):
        raise HTTPException(status_code=503, detail=f"worker disabled: {name}")
    return node



def normalize_node(name: str, node: dict[str, Any]) -> dict[str, Any]:
    role = node.get("role", "general")
    primary_role = node.get("primary_role") or role
    secondary_roles = node.get("secondary_roles") or []

    return {
        "name": name,
        "role": role,
        "primary_role": primary_role,
        "secondary_roles": secondary_roles,
        "base_url": str(node["base_url"]).rstrip("/"),
        "gpu_count": node.get("gpu_count"),
        "enabled": node.get("enabled", True),
        "notes": node.get("notes"),
    }



def fleet_view() -> dict[str, dict[str, Any]]:
    return {name: normalize_node(name, node) for name, node in FLEET.items()}



def load_gpu_inventory() -> dict[str, Any]:
    try:
        with GPU_INVENTORY_PATH.open("r", encoding="utf-8") as f:
            return json.load(f)
    except Exception as exc:
        return {"error": str(exc)}



def get_gpu_inventory_runtime() -> dict[str, Any]:
    return load_gpu_inventory()



def load_fleet_status() -> dict[str, Any]:
    try:
        with FLEET_STATUS_PATH.open("r", encoding="utf-8") as f:
            return json.load(f)
    except Exception:
        return {"hosts": {}}



def worker_status(name: str) -> dict[str, Any]:
    return load_fleet_status().get("hosts", {}).get(name, {})



def worker_metric_int(status: dict[str, Any], key: str, default: int = 0) -> int:
    try:
        return int(status.get(key, default))
    except Exception:
        return default



def worker_metric_float(status: dict[str, Any], key: str, default: float = 0.0) -> float:
    try:
        return float(status.get(key, default))
    except Exception:
        return default



def worker_running_jobs(worker_name: str, status: dict[str, Any]) -> int:
    active = ACTIVE_REQUESTS.get(worker_name, 0)
    if active > 0:
        return active
    return worker_metric_int(status, "running_jobs", 0)



def gpu_running_jobs(worker_name: str, gpu_lane: str) -> int:
    return ACTIVE_GPU_REQUESTS.get(worker_name, {}).get(gpu_lane, 0)



def increment_active(worker_name: str, gpu_lane: str) -> None:
    ACTIVE_REQUESTS[worker_name] = ACTIVE_REQUESTS.get(worker_name, 0) + 1
    ACTIVE_GPU_REQUESTS.setdefault(worker_name, {})
    ACTIVE_GPU_REQUESTS[worker_name][gpu_lane] = ACTIVE_GPU_REQUESTS[worker_name].get(gpu_lane, 0) + 1



def decrement_active(worker_name: str, gpu_lane: str) -> None:
    if worker_name in ACTIVE_REQUESTS:
        ACTIVE_REQUESTS[worker_name] = max(0, ACTIVE_REQUESTS[worker_name] - 1)
    if worker_name in ACTIVE_GPU_REQUESTS and gpu_lane in ACTIVE_GPU_REQUESTS[worker_name]:
        ACTIVE_GPU_REQUESTS[worker_name][gpu_lane] = max(0, ACTIVE_GPU_REQUESTS[worker_name][gpu_lane] - 1)



def is_worker_eligible(name: str, fleet_status: dict[str, Any]) -> bool:
    status = fleet_status.get(name, {})
    return bool(status.get("eligible", False))



def candidate_workers(role: str) -> list[dict[str, Any]]:
    ordered_names = ROLE_PRIORITY.get(role, ROLE_PRIORITY["general"])
    fleet_status = load_fleet_status().get("hosts", {})

    out: list[dict[str, Any]] = []
    seen: set[str] = set()

    for name in ordered_names:
        node = FLEET.get(name)
        if not node or not node.get("enabled", True):
            continue
        if not is_worker_eligible(name, fleet_status):
            continue
        out.append(normalize_node(name, node))
        seen.add(name)

    for name, node in FLEET.items():
        if name in seen or not node.get("enabled", True):
            continue
        if not is_worker_eligible(name, fleet_status):
            continue
        out.append(normalize_node(name, node))

    return out


async def ping_worker(base_url: str, timeout_sec: int = 10) -> tuple[bool, str]:
    test_url = f"{base_url.rstrip('/')}/api/tags"
    try:
        async with httpx.AsyncClient(timeout=timeout_sec) as client:
            resp = await client.get(test_url)
            if resp.status_code == 200:
                return True, "ok"
            return False, f"http {resp.status_code}"
    except Exception as exc:
        return False, str(exc)


async def list_worker_models(base_url: str, timeout_sec: int = 20) -> list[str]:
    url = f"{base_url.rstrip('/')}/api/tags"
    async with httpx.AsyncClient(timeout=timeout_sec) as client:
        resp = await client.get(url)

    if resp.status_code != 200:
        raise HTTPException(
            status_code=502,
            detail={
                "message": "worker returned non-200 from /api/tags",
                "worker_url": base_url,
                "status_code": resp.status_code,
                "body": resp.text,
            },
        )

    data = resp.json()
    return [m.get("name") for m in data.get("models", []) if m.get("name")]



def select_preferred_models(
    role: str,
    requested_model: str | None,
    allow_fallback: bool,
    lane_policy: dict[str, Any],
) -> list[str]:
    preferred = list(lane_policy.get("model_preferences", {}).get(role, []))

    if requested_model:
        if allow_fallback:
            return [requested_model] + [m for m in preferred if m != requested_model]
        return [requested_model]

    return preferred



def worker_admission_allowed(worker_name: str, role: str, status: dict[str, Any]) -> tuple[bool, str]:
    policy = WORKER_POLICY.get(worker_name)
    if not policy:
        return False, "no_worker_policy"

    class_limit = int(policy.get("class_limits", {}).get(role, 0))
    if class_limit <= 0:
        return False, f"role_not_allowed:{role}"

    running_total = worker_running_jobs(worker_name, status)
    if running_total >= int(policy.get("max_total", 0)):
        return False, "worker_at_capacity"

    if role == "heavy" and running_total > 0:
        return False, "heavy_exclusive_busy"

    return True, "ok"



def lane_admission_allowed(worker_name: str, gpu_lane: str) -> tuple[bool, str]:
    policy = WORKER_POLICY.get(worker_name, {})
    lane_policy = policy.get("gpu_routes", {}).get(gpu_lane, {})

    if not lane_policy:
        return False, "unknown_gpu_lane"

    running = gpu_running_jobs(worker_name, gpu_lane)
    if running >= int(lane_policy.get("max_total", 0)):
        return False, "gpu_lane_at_capacity"

    return True, "ok"



def score_candidate(
    role: str,
    requested_model: str | None,
    worker_name: str,
    gpu_lane: str,
    node: dict[str, Any],
    status: dict[str, Any],
    model: str,
) -> int:
    score = 0

    if model == requested_model:
        score += 100

    priority_list = ROLE_PRIORITY.get(role, [])
    if worker_name in priority_list:
        score += max(0, 60 - (priority_list.index(worker_name) * 12))

    lane_label = WORKER_POLICY.get(worker_name, {}).get("gpu_routes", {}).get(gpu_lane, {}).get("label", "")

    if role == "heavy":
        if worker_name == "spot-worker-04":
            score += 45
        elif worker_name == "spot-worker-03" and gpu_lane == "gpu1":
            score += 40
        elif worker_name == "spot-worker-01":
            score += 15

    elif role == "coding":
        if worker_name == "spot-worker-03" and gpu_lane == "gpu1":
            score += 45
        elif worker_name == "spot-worker-03" and gpu_lane == "gpu0":
            score += 35
        elif worker_name == "spot-worker-01":
            score += 10

    elif role == "general":
        if worker_name == "spot-worker-01":
            score += 35
        elif worker_name == "spot-worker-04":
            score += 15
        elif worker_name == "spot-worker-03":
            score += 10

    elif role == "utility":
        if worker_name == "spot-worker-02" and gpu_lane == "gpu0":
            score += 45
        elif worker_name == "spot-worker-02" and gpu_lane == "gpu1":
            score += 20

    elif role == "watcher":
        if worker_name == "spot-worker-02" and gpu_lane == "gpu1":
            score += 50

    gpu_free_mb_max = worker_metric_int(status, "gpu_free_mb_max", 0)
    gpu_vram_total_mb_max = worker_metric_int(status, "gpu_vram_total_mb_max", 0)
    load_1 = worker_metric_float(status, "load_1", 0.0)
    running_jobs = worker_running_jobs(worker_name, status)
    lane_jobs = gpu_running_jobs(worker_name, gpu_lane)

    if gpu_free_mb_max >= 11000:
        score += 30
    elif gpu_free_mb_max >= 9000:
        score += 20
    elif gpu_free_mb_max >= 7000:
        score += 8

    if role == "heavy":
        if gpu_vram_total_mb_max >= 12000:
            score += 25
        elif gpu_vram_total_mb_max >= 10000:
            score += 8
        else:
            score -= 30

    if load_1 <= 1.0:
        score += 12
    elif load_1 <= 2.5:
        score += 5
    elif load_1 > 4.0:
        score -= 20

    if "RTX 3060" in lane_label:
        score += 8
    if "TITAN Xp" in lane_label:
        score += 10
    if "GTX 1070" in lane_label and role == "coding":
        score += 6
    if "GTX 1060" in lane_label and role == "watcher":
        score += 8

    score -= running_jobs * 12
    score -= lane_jobs * 25

    return score


async def choose_worker_and_model(
    role: str,
    requested_model: str | None,
    forced_worker: str | None = None,
    forced_gpu_lane: str | None = None,
    allow_fallback: bool = True,
) -> tuple[dict[str, Any], str, str, str]:
    if role not in ROLE_PRIORITY:
        raise HTTPException(status_code=400, detail={"message": "unsupported role", "role": role})

    if forced_worker:
        node = normalize_node(forced_worker, load_node(forced_worker))
        status = worker_status(forced_worker)

        allowed, reason = worker_admission_allowed(forced_worker, role, status)
        if not allowed:
            raise HTTPException(status_code=503, detail={"message": "forced worker rejected", "worker": forced_worker, "reason": reason})

        ok, ping_reason = await ping_worker(node["base_url"])
        if not ok:
            raise HTTPException(status_code=503, detail={"message": "forced worker unavailable", "worker": forced_worker, "reason": ping_reason})

        installed = await list_worker_models(node["base_url"])
        worker_policy = WORKER_POLICY.get(forced_worker, {})
        gpu_routes = worker_policy.get("gpu_routes", {})

        lanes = [forced_gpu_lane] if forced_gpu_lane else list(gpu_routes.keys())
        for gpu_lane in lanes:
            lane_policy = gpu_routes.get(gpu_lane)
            if not lane_policy:
                continue
            if role not in lane_policy.get("classes", set()):
                continue
            lane_allowed, lane_reason = lane_admission_allowed(forced_worker, gpu_lane)
            if not lane_allowed:
                continue
            preferred_models = select_preferred_models(role, requested_model, allow_fallback, lane_policy)
            for model in preferred_models:
                if model in installed:
                    return node, model, gpu_lane, lane_policy.get("label", gpu_lane)

        raise HTTPException(
            status_code=404,
            detail={
                "message": "forced worker has no usable lane/model",
                "worker": forced_worker,
                "gpu_lane": forced_gpu_lane,
                "role": role,
                "requested_model": requested_model,
                "installed_models": installed,
            },
        )

    candidates = candidate_workers(role)
    if not candidates:
        raise HTTPException(status_code=404, detail={"message": "no eligible registered workers available", "role": role})

    failures: list[dict[str, Any]] = []
    scored: list[tuple[int, dict[str, Any], str, str, str, dict[str, Any]]] = []

    for node in candidates:
        worker_name = node["name"]
        status = worker_status(worker_name)

        allowed, reason = worker_admission_allowed(worker_name, role, status)
        if not allowed:
            failures.append({"worker": worker_name, "reason": reason, "stage": "admission"})
            continue

        ok, reason = await ping_worker(node["base_url"])
        if not ok:
            failures.append({"worker": worker_name, "reason": reason, "stage": "health"})
            continue

        try:
            installed = await list_worker_models(node["base_url"])
        except Exception as exc:
            failures.append({"worker": worker_name, "reason": str(exc), "stage": "inventory"})
            continue

        worker_policy = WORKER_POLICY.get(worker_name, {})
        for gpu_lane, lane_policy in worker_policy.get("gpu_routes", {}).items():
            if role not in lane_policy.get("classes", set()):
                continue

            lane_allowed, lane_reason = lane_admission_allowed(worker_name, gpu_lane)
            if not lane_allowed:
                failures.append({"worker": worker_name, "gpu_lane": gpu_lane, "reason": lane_reason, "stage": "gpu_admission"})
                continue

            preferred_models = select_preferred_models(role, requested_model, allow_fallback, lane_policy)
            for model in preferred_models:
                if model not in installed:
                    continue

                score = score_candidate(role, requested_model, worker_name, gpu_lane, node, status, model)
                scored.append(
                    (
                        score,
                        node,
                        model,
                        gpu_lane,
                        lane_policy.get("label", gpu_lane),
                        {
                            "gpu_free_mb_max": worker_metric_int(status, "gpu_free_mb_max", 0),
                            "gpu_vram_total_mb_max": worker_metric_int(status, "gpu_vram_total_mb_max", 0),
                            "load_1": worker_metric_float(status, "load_1", 0.0),
                            "running_jobs": worker_running_jobs(worker_name, status),
                            "lane_jobs": gpu_running_jobs(worker_name, gpu_lane),
                        },
                    )
                )

    if scored:
        scored.sort(key=lambda x: x[0], reverse=True)
        print("SCHEDULER SCORES:")
        for s, n, m, gpu_lane, gpu_label, meta in scored:
            print(
                f"{n['name']}:{gpu_lane} ({gpu_label}) -> {m} = {s} "
                f"(free={meta['gpu_free_mb_max']} total={meta['gpu_vram_total_mb_max']} "
                f"load1={meta['load_1']} jobs={meta['running_jobs']} lane_jobs={meta['lane_jobs']})"
            )

        best = scored[0]
        return best[1], best[2], best[3], best[4]

    raise HTTPException(
        status_code=503,
        detail={
            "message": f"no healthy eligible workers with an admissible lane/model for role '{role}'",
            "failures": failures,
        },
    )


async def call_ollama_generate(base_url: str, req: ExecRequest, model: str) -> dict[str, Any]:
    url = f"{base_url.rstrip('/')}/api/generate"
    payload: dict[str, Any] = {"model": model, "prompt": req.prompt, "stream": req.stream}

    options: dict[str, Any] = {}
    if req.temperature is not None:
        options["temperature"] = req.temperature
    if req.num_predict is not None:
        options["num_predict"] = req.num_predict
    if options:
        payload["options"] = options
    if req.system:
        payload["system"] = req.system

    async with httpx.AsyncClient(timeout=req.timeout_sec) as client:
        resp = await client.post(url, json=payload)

    if resp.status_code != 200:
        raise HTTPException(
            status_code=502,
            detail={
                "message": "worker returned non-200 from /api/generate",
                "worker_url": base_url,
                "status_code": resp.status_code,
                "body": resp.text,
            },
        )

    return resp.json()


async def call_ollama_embed(base_url: str, req: ExecRequest, model: str) -> dict[str, Any]:
    url = f"{base_url.rstrip('/')}/api/embed"
    payload = {"model": model, "input": req.prompt}

    async with httpx.AsyncClient(timeout=req.timeout_sec) as client:
        resp = await client.post(url, json=payload)

    if resp.status_code != 200:
        raise HTTPException(
            status_code=502,
            detail={
                "message": "worker returned non-200 from /api/embed",
                "worker_url": base_url,
                "status_code": resp.status_code,
                "body": resp.text,
            },
        )

    return resp.json()



