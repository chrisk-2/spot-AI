[Unit]
Description=Spot Worker Helper
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
EnvironmentFile=/etc/spot-worker.env
WorkingDirectory=/opt/spot-worker
ExecStart=/opt/spot-worker/.venv/bin/uvicorn app:APP --host 0.0.0.0 --port 8788
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
