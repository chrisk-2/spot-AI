<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>ReadyRoom — Spot</title>
  <style>
    body { margin:0; font-family: system-ui, sans-serif; background:#0b0f14; color:#e8eef7; }
    .wrap { display:grid; grid-template-columns: 1fr 1fr; height:100vh; }
    .panel { padding:18px; box-sizing:border-box; }

    /* Face Panel */
    .facebox { display:flex; align-items:center; justify-content:center; height:100%; }
    .avatar {
      position: relative;
      width: min(70vh, 45vw);
      aspect-ratio: 2 / 3;
      border-radius: 18px;
      overflow:hidden;
      box-shadow: 0 0 40px rgba(0,0,0,.6);
      background:#000;
    }
    .avatar img { width:100%; height:100%; object-fit: cover; display:block; }

    /* Chat Panel */
    .chatbox { display:flex; flex-direction:column; height:100%; }
    .messages {
      flex:1;
      overflow:auto;
      padding:10px;
      background:#111822;
      border-radius:12px;
      margin-bottom:10px;
    }
    .msg { margin-bottom:12px; }
    .user { color:#6cf; }
    .assistant { color:#e8eef7; }

    .inputrow { display:flex; gap:8px; }
    input[type="text"] {
      flex:1;
      padding:10px;
      border-radius:8px;
      border:none;
      background:#1c2533;
      color:#fff;
    }
    button {
      padding:10px 16px;
      border-radius:8px;
      border:none;
      background:#2d9cdb;
      color:#fff;
      cursor:pointer;
    }
    button:disabled { opacity:.6; cursor:not-allowed; }

    .telemetry {
      font-size:12px;
      margin-top:6px;
      color:#6cf;
      opacity:.9;
    }

    .status {
      font-size:12px;
      color:#ffa;
      margin-top:4px;
    }
  </style>
</head>
<body>
<div class="wrap">

  <!-- FACE -->
  <div class="panel facebox">
    <div class="avatar">
      <img src="/static/spot-face.png" alt="Spot"/>
    </div>
  </div>

  <!-- CHAT -->
  <div class="panel chatbox">
    <div class="messages" id="messages"></div>

    <div class="inputrow">
      <input id="prompt" type="text" placeholder="Speak to Spot..." />
      <button id="sendBtn">Send</button>
    </div>

    <div class="status" id="status"></div>
    <div class="telemetry" id="telemetry"></div>
  </div>

</div>

<script>
const messages = document.getElementById("messages");
const promptInput = document.getElementById("prompt");
const sendBtn = document.getElementById("sendBtn");
const telemetry = document.getElementById("telemetry");
const statusEl = document.getElementById("status");

function addMessage(text, cls) {
  const div = document.createElement("div");
  div.className = "msg " + cls;
  div.textContent = text;
  messages.appendChild(div);
  messages.scrollTop = messages.scrollHeight;
}

async function sendMessage() {
  const prompt = promptInput.value.trim();
  if (!prompt) return;

  addMessage("You: " + prompt, "user");
  promptInput.value = "";
  sendBtn.disabled = true;
  statusEl.textContent = "COMPUTING…";
  telemetry.textContent = "";

  try {
    const r = await fetch("/api/chat", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ prompt: prompt, top_k: 6 })
    });

    const data = await r.json();

    if (!data.ok) {
      addMessage("Error: " + (data.error || "Unknown error"), "assistant");
      statusEl.textContent = "";
      sendBtn.disabled = false;
      return;
    }

    addMessage("Spot: " + data.response.trim(), "assistant");

    if (data.metrics) {
      const m = data.metrics;
      telemetry.textContent =
        `Model: ${data.model}  |  TPS: ${m.tokens_per_sec}  |  Eval Tokens: ${m.eval_count}`;
    }

    statusEl.textContent = "";
    sendBtn.disabled = false;

  } catch (err) {
    addMessage("Network error: " + err, "assistant");
    statusEl.textContent = "";
    sendBtn.disabled = false;
  }
}

sendBtn.addEventListener("click", sendMessage);
promptInput.addEventListener("keydown", e => {
  if (e.key === "Enter") sendMessage();
});
</script>
</body>
</html>
