import os
import time
import json
from typing import Any, Dict, Optional, Tuple, List

import requests
from fastapi import FastAPI, Request
from fastapi.responses import JSONResponse


APP = FastAPI(title="Spot Gateway (chat + tools)")


def env(name: str, default: str = "") -> str:
    return (os.environ.get(name, default) or "").strip()


SPOTD_URL = env("SPOTD_URL", "http://127.0.0.1:8797").rstrip("/")
OLLAMA_URL = env("OLLAMA_URL", "http://127.0.0.1:11434").rstrip("/")
OLLAMA_MODEL = env("OLLAMA_MODEL", "llama3.1:8b").strip() or "llama3.1:8b"
HTTP_TIMEOUT_SEC = int(env("HTTP_TIMEOUT_SEC", "300") or "300")

ALLOWED_WORKERS = [w.strip() for w in env("ALLOWED_WORKERS", "spot_helper").split(",") if w.strip()]
ALLOWED_CMDS = [c.strip() for c in env("ALLOWED_CMDS", "ping,uptime,df,nvidia_smi").split(",") if c.strip()]


def ok(payload: Dict[str, Any], code: int = 200) -> JSONResponse:
    return JSONResponse(payload, status_code=code)


def err(code: str, http_status: int, **extra) -> JSONResponse:
    return JSONResponse({"ok": False, "error": code, **extra}, status_code=http_status)


@APP.get("/health")
def health():
    return {"ok": True, "ts": int(time.time())}


@APP.get("/tools")
def tools():
    return ok(
        {
            "ok": True,
            "spotd_url": SPOTD_URL,
            "workers": ALLOWED_WORKERS,
            "allowed_cmds": ALLOWED_CMDS,
        }
    )


def _enforce_allowlists(worker: str, cmd: str) -> Optional[JSONResponse]:
    if worker not in ALLOWED_WORKERS:
        return err("worker_not_allowed", 403, worker=worker, allowed_workers=ALLOWED_WORKERS)
    if cmd not in ALLOWED_CMDS:
        return err("cmd_not_allowed", 403, cmd=cmd, allowed_cmds=ALLOWED_CMDS)
    return None


def _worker_endpoint(worker: str) -> Optional[Tuple[str, str]]:
    """
    Map a logical worker name -> (base_url, exec_token) for direct calls.
    """
    if worker == "m5_exec":
        return (env("M5_EXEC_URL", "").rstrip("/"), env("M5_EXEC_TOKEN", ""))
    if worker == "m5_watch":
        return (env("M5_WATCH_URL", "").rstrip("/"), env("M5_WATCH_TOKEN", ""))
    return None


def _direct_worker_exec(worker: str, cmd: str, args: Optional[Dict[str, Any]] = None) -> JSONResponse:
    ep = _worker_endpoint(worker)
    if not ep:
        return err("worker_not_direct", 400, worker=worker)

    base_url, token = ep
    if not base_url or not token:
        return err("worker_direct_not_configured", 500, worker=worker, base_url=base_url, token_set=bool(token))

    payload: Dict[str, Any] = {"cmd": cmd}
    if args:
        payload["args"] = args

    try:
        r = requests.post(
            f"{base_url}/exec",
            json=payload,
            headers={"x-exec-token": token},
            timeout=HTTP_TIMEOUT_SEC,
        )
    except Exception as e:
        return err("worker_unreachable", 502, worker=worker, detail=str(e), url=base_url)

    try:
        data = r.json()
    except Exception:
        return err("non_json_response_from_worker", 502, worker=worker, status=r.status_code, text=(r.text or "")[:1000])

    return JSONResponse(data, status_code=r.status_code)


def _safe_int(x: Any, default: int = -1) -> int:
    try:
        return int(str(x).strip())
    except Exception:
        return default


def _parse_int_from_stdout(s: str) -> Optional[int]:
    try:
        return int((s or "").strip().splitlines()[0].strip())
    except Exception:
        return None


def _parse_gpu_util(stdout: str) -> Dict[str, Any]:
    """
    Expects a single line like:
      "0, 0 %, 0 %, 38, 12.99 W"
    Returns parsed fields; if parsing fails, returns {"raw": "..."}.
    """
    line = (stdout or "").strip().splitlines()[0].strip() if (stdout or "").strip() else ""
    if not line:
        return {"raw": stdout or ""}

    parts = [p.strip() for p in line.split(",")]
    if len(parts) < 5:
        return {"raw": line}

    def pct(x: str) -> Optional[int]:
        try:
            return int(x.replace("%", "").strip())
        except Exception:
            return None

    def flt(x: str) -> Optional[float]:
        try:
            return float(x.replace("W", "").strip())
        except Exception:
            return None

    util_gpu = pct(parts[1])
    util_mem = pct(parts[2])
    temp_c = None
    try:
        temp_c = int(parts[3].strip())
    except Exception:
        temp_c = None
    power_w = flt(parts[4])

    return {
        "raw": line,
        "util_gpu_pct": util_gpu,
        "util_mem_pct": util_mem,
        "temp_c": temp_c,
        "power_w": power_w,
    }


def _call_worker_json(worker: str, path: str, method: str = "GET", payload: Optional[Dict[str, Any]] = None) -> Dict[str, Any]:
    """
    Calls a worker endpoint and returns decoded JSON dict, or {"ok": False, ...}.
    Adds x-exec-token if configured. (Workers /status doesn't require it, but harmless.)
    """
    ep = _worker_endpoint(worker)
    if not ep:
        return {"ok": False, "error": "worker_not_direct", "worker": worker}

    base_url, token = ep
    if not base_url:
        return {"ok": False, "error": "worker_direct_not_configured", "worker": worker, "base_url": base_url}

    headers = {}
    if token:
        headers["x-exec-token"] = token

    url = f"{base_url.rstrip('/')}/{path.lstrip('/')}"
    try:
        if method.upper() == "GET":
            r = requests.get(url, headers=headers, timeout=10)
        else:
            r = requests.post(url, json=(payload or {}), headers=headers, timeout=HTTP_TIMEOUT_SEC)

        return r.json()
    except Exception as e:
        return {"ok": False, "error": "worker_call_failed", "worker": worker, "url": url, "detail": str(e)}


def _get_status_map() -> Dict[str, Any]:
    """
    Fetch /status from each direct worker we know about AND that is allowed.
    Keys are logical names (m5_exec, m5_watch).
    """
    status_map: Dict[str, Any] = {}
    for w in ("m5_exec", "m5_watch"):
        if w not in ALLOWED_WORKERS:
            continue
        status_map[w] = _call_worker_json(w, "/status", method="GET")
    return status_map


def _pick_exec_watch_by_vram(status_map: Dict[str, Any]) -> Tuple[Optional[str], Optional[str]]:
    """
    Pick exec/watch from available status_map by vram_free_mb (descending).
    Returns (exec_worker, watch_worker) logical names.
    """
    candidates: List[Tuple[int, str]] = []
    for name, st in status_map.items():
        if not isinstance(st, dict) or not st.get("ok"):
            continue
        v = _safe_int(st.get("vram_free_mb", -1), -1)
        candidates.append((v, name))

    candidates.sort(reverse=True)
    exec_name = candidates[0][1] if len(candidates) >= 1 else None
    watch_name = candidates[1][1] if len(candidates) >= 2 else None
    return exec_name, watch_name


def _gpu_status() -> JSONResponse:
    """
    NEW: Gather /status for each direct worker, then auto-assign exec/watch by vram_free_mb.
    Still returns m5_exec/m5_watch keys for backward compatibility, but they now point at
    the chosen roles (and include which logical worker was used).
    """
    out: Dict[str, Any] = {"ok": True, "ts": int(time.time())}

    status_map = _get_status_map()
    exec_worker, watch_worker = _pick_exec_watch_by_vram(status_map)

    out["workers"] = status_map
    out["exec_worker"] = exec_worker
    out["watch_worker"] = watch_worker

    if exec_worker:
        out["m5_exec"] = status_map.get(exec_worker, {"ok": False, "error": "missing_status"})
        if isinstance(out["m5_exec"], dict):
            out["m5_exec"]["logical_worker"] = exec_worker

    if watch_worker:
        out["m5_watch"] = status_map.get(watch_worker, {"ok": False, "error": "missing_status"})
        if isinstance(out["m5_watch"], dict):
            out["m5_watch"]["logical_worker"] = watch_worker

    return ok(out)


def _auto_pick_worker(args: Dict[str, Any]) -> JSONResponse:
    """
    NEW: Choose between m5_exec and m5_watch using /status.
      1) min_vram_mb threshold (vram_free_mb)
      2) lowest gpu utilization (status["gpu_util"]["util_gpu_pct"])
      3) highest free vram as tie-breaker

    Returns chosen_worker + reason + metrics.
    """
    min_vram_mb = int((args or {}).get("min_vram_mb", 0) or 0)

    workers = [w for w in ("m5_exec", "m5_watch") if w in ALLOWED_WORKERS]
    if not workers:
        return err("no_candidate_workers", 400, allowed_workers=ALLOWED_WORKERS)

    metrics: Dict[str, Any] = {}
    scored: List[Tuple[bool, int, int, str]] = []

    for w in workers:
        st = _call_worker_json(w, "/status", method="GET")
        if not isinstance(st, dict):
            metrics[w] = {"error": "status_not_dict"}
            continue

        metrics[w] = st

        vram_mb = _safe_int(st.get("vram_free_mb", -1), -1)
        util_obj = st.get("gpu_util") if isinstance(st.get("gpu_util"), dict) else {}
        util_gpu = util_obj.get("util_gpu_pct", None)
        util_score = util_gpu if isinstance(util_gpu, int) else 999

        meets = (vram_mb >= min_vram_mb) if vram_mb >= 0 else False
        # score: meets threshold first, then lowest util, then highest vram
        scored.append((meets, util_score, -vram_mb, w))

    if not scored:
        return err("no_metrics", 502)

    meets_any = any(s[0] for s in scored)
    if meets_any:
        candidates = [s for s in scored if s[0]]
        candidates.sort(key=lambda x: (x[1], x[2]))
        chosen = candidates[0][3]
    else:
        # best effort: highest vram, then lowest util
        candidates = scored[:]
        candidates.sort(key=lambda x: (x[2], x[1]))  # x[2] is -vram
        chosen = candidates[0][3]

    chosen_m = metrics.get(chosen, {})
    vram_mb = _safe_int(chosen_m.get("vram_free_mb", -1), -1)
    util_obj = chosen_m.get("gpu_util") if isinstance(chosen_m.get("gpu_util"), dict) else {}
    util_gpu = util_obj.get("util_gpu_pct", None)

    if meets_any:
        reason = f"Picked {chosen} because {vram_mb}MB free >= {min_vram_mb}MB and util {util_gpu}%"
    else:
        reason = f"Picked {chosen} because no worker met {min_vram_mb}MB; best available vram {vram_mb}MB and util {util_gpu}%"

    return ok(
        {
            "ok": True,
            "ts": int(time.time()),
            "chosen_worker": chosen,
            "reason": reason,
            "min_vram_mb": min_vram_mb,
            "metrics": metrics,
        }
    )


def _auto_exec(args: Dict[str, Any]) -> JSONResponse:
    """
    Convenience: pick a worker, then run subcmd on it.
    """
    subcmd = (args or {}).get("subcmd", None)
    if not subcmd or not isinstance(subcmd, str):
        return err("subcmd_required", 400)

    min_vram_mb = int((args or {}).get("min_vram_mb", 0) or 0)

    # pick as python dict
    pick_resp = _auto_pick_worker({"min_vram_mb": min_vram_mb})
    try:
        pick_obj = json.loads(pick_resp.body.decode("utf-8"))  # type: ignore
    except Exception:
        return err("pick_failed", 502)

    chosen = pick_obj.get("chosen_worker")
    if not chosen:
        return err("pick_failed", 502)

    # Execute the subcmd directly on the chosen worker
    ep = _worker_endpoint(chosen)
    if not ep:
        return err("chosen_not_direct", 500, chosen_worker=chosen)

    base_url, token = ep
    try:
        r = requests.post(
            f"{base_url}/exec",
            json={"cmd": subcmd},
            headers={"x-exec-token": token} if token else {},
            timeout=HTTP_TIMEOUT_SEC,
        )
        data = r.json()
    except Exception as e:
        return err("exec_failed", 502, chosen_worker=chosen, detail=str(e))

    return ok(
        {
            "ok": True,
            "chosen_worker": chosen,
            "min_vram_mb": min_vram_mb,
            "subcmd": subcmd,
            "reason": pick_obj.get("reason"),
            "metrics": pick_obj.get("metrics"),
            "result": data,
        }
    )


async def _do_worker_exec(body: Dict[str, Any]) -> JSONResponse:
    """
    Internal implementation shared by /tool/exec and /worker/exec.
    Supports meta-commands:
      - gpu_status
      - auto_pick_worker
      - auto_exec
    Otherwise forwards to spotd /worker/exec.
    """
    worker = (body.get("worker") or "").strip()
    cmd = (body.get("cmd") or "").strip()
    args = body.get("args") if isinstance(body.get("args"), dict) else {}

    token_override = body.get("token_override", None)

    if not worker or not cmd:
        return err("worker_and_cmd_required", 400)

    denied = _enforce_allowlists(worker, cmd)
    if denied:
        return denied

    # Meta commands (run inside gateway)
    if cmd == "gpu_status":
        return _gpu_status()
    if cmd == "auto_pick_worker":
        return _auto_pick_worker(args)
    if cmd == "auto_exec":
        return _auto_exec(args)

    # Direct worker commands (optional convenience)
    if worker in ("m5_exec", "m5_watch"):
        return _direct_worker_exec(worker, cmd, args=args)

    # Default: forward to spotd
    try:
        r = requests.post(
            f"{SPOTD_URL}/worker/exec",
            json={"worker": worker, "cmd": cmd, "token_override": token_override, "args": args},
            timeout=HTTP_TIMEOUT_SEC,
        )
    except Exception as e:
        return err("spotd_unreachable", 502, detail=str(e), spotd_url=SPOTD_URL)

    try:
        data = r.json()
    except Exception:
        return err(
            "non_json_response_from_spotd",
            502,
            status=r.status_code,
            text=(r.text or "")[:1000],
        )

    return JSONResponse(data, status_code=r.status_code)


@APP.post("/chat")
async def chat(req: Request):
    """
    Compatibility endpoint: some clients POST /chat to the gateway.
    Forward to spotd (/chat) so the UI doesn't get 404s.
    """
    try:
        body = await req.json()
    except Exception:
        return err("bad_json", 400)

    try:
        r = requests.post(
            f"{SPOTD_URL}/chat",
            json=body,
            timeout=HTTP_TIMEOUT_SEC,
        )
    except Exception as e:
        return err("spotd_unreachable", 502, detail=str(e), spotd_url=SPOTD_URL)

    # Prefer JSON, fall back to text
    try:
        data = r.json()
        return JSONResponse(data, status_code=r.status_code)
    except Exception:
        return JSONResponse(
            {"ok": False, "error": "non_json_response_from_spotd", "status": r.status_code, "text": (r.text or "")[:2000]},
            status_code=502,
        )
@APP.post("/tool/exec")
async def tool_exec(req: Request):
    body = await req.json()
    return await _do_worker_exec(body)


@APP.post("/worker/exec")
async def worker_exec(req: Request):
    body = await req.json()
    return await _do_worker_exec(body)
