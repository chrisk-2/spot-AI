import os
import time
from typing import Any, Dict, Optional

import requests
from fastapi import FastAPI, Request
from fastapi.responses import JSONResponse

APP = FastAPI(title="Spot Gateway (chat + tools)")


def env(name: str, default: str = "") -> str:
    return (os.environ.get(name, default) or "").strip()


# Core endpoints
SPOTD_URL = env("SPOTD_URL", "http://127.0.0.1:8797").rstrip("/")
OLLAMA_URL = env("OLLAMA_URL", "http://127.0.0.1:11434").rstrip("/")
OLLAMA_MODEL = env("OLLAMA_MODEL", "llama3.1:8b").strip()

# M-5 routing (direct-to-worker)
M5_EXEC_URL = env("M5_EXEC_URL", "").rstrip("/")       # exec = 8GB worker
M5_EXEC_TOKEN = env("M5_EXEC_TOKEN", "")
M5_WATCH_URL = env("M5_WATCH_URL", "").rstrip("/")     # watch = 6GB worker
M5_WATCH_TOKEN = env("M5_WATCH_TOKEN", "")

HTTP_TIMEOUT_SEC = int(env("HTTP_TIMEOUT_SEC", "300") or "300")
AUTO_PICK_MIN_VRAM_MB = int(env("AUTO_PICK_MIN_VRAM_MB", "7000") or "7000")
AUTO_EXEC_MIN_VRAM_MB = int(env("AUTO_EXEC_MIN_VRAM_MB", "7000") or "7000")

# Allowlists
# Example:
#   ALLOWED_WORKERS="spot_helper,m5_exec,m5_watch"
#   ALLOWED_CMDS="ping,uptime,df,nvidia_smi,os_build,cuda_probe,vram_mb,gpu_status,auto_pick_worker,auto_exec"
ALLOWED_WORKERS = [w.strip() for w in env("ALLOWED_WORKERS", "spot_helper").split(",") if w.strip()]
ALLOWED_CMDS = [c.strip() for c in env("ALLOWED_CMDS", "ping,uptime,df,nvidia_smi").split(",") if c.strip()]


def ok(payload: Dict[str, Any], status: int = 200) -> JSONResponse:
    return JSONResponse(payload, status_code=status)


def err(code: str, status: int, **extra: Any) -> JSONResponse:
    payload = {"ok": False, "error": code}
    payload.update(extra)
    return JSONResponse(payload, status_code=status)


@APP.get("/health")
def health():
    return ok({"ok": True})


@APP.get("/tools")
def tools():
    return ok(
        {
            "ok": True,
            "spotd_url": SPOTD_URL,
            "workers": ALLOWED_WORKERS,
            "allowed_cmds": ALLOWED_CMDS,
        }
    )


@APP.post("/chat")
async def chat(req: Request):
    """
    Minimal chat endpoint that proxies to Ollama /api/generate.
    Body:
      {
        "prompt": "...",
        "model": "optional",
        "options": {... optional ...}
      }
    """
    body = await req.json()
    prompt = (body.get("prompt") or "").strip()
    if not prompt:
        return err("prompt_required", 400)

    model = (body.get("model") or OLLAMA_MODEL).strip() or OLLAMA_MODEL
    options = body.get("options", None)

    payload: Dict[str, Any] = {"model": model, "prompt": prompt, "stream": False}
    if isinstance(options, dict):
        payload["options"] = options

    try:
        r = requests.post(f"{OLLAMA_URL}/api/generate", json=payload, timeout=HTTP_TIMEOUT_SEC)
    except Exception as e:
        return err("ollama_unreachable", 502, detail=str(e), ollama_url=OLLAMA_URL)

    try:
        data = r.json()
    except Exception:
        return err("non_json_response_from_ollama", 502, status=r.status_code, text=(r.text or "")[:1000])

    # metrics (ns) from Ollama
    total_duration = data.get("total_duration", 0)
    eval_duration = data.get("eval_duration", 0)
    eval_count = data.get("eval_count", 0)

    tps = 0.0
    if eval_duration and eval_count:
        tps = eval_count / (eval_duration / 1e9)

    return ok(
        {
            "ok": True,
            "response": (data.get("response") or ""),
            "model": (data.get("model") or model),
            "metrics": {
                "total_duration_ns": total_duration,
                "eval_duration_ns": eval_duration,
                "eval_count": eval_count,
                "tokens_per_sec": round(tps, 2),
            },
            "raw": data,  # keep raw so we can debug/expand later
        },
        status=r.status_code if r.status_code >= 400 else 200,
    )


def _enforce_allowlists(worker: str, cmd: str) -> Optional[JSONResponse]:
    if worker not in ALLOWED_WORKERS:
        return err("worker_not_allowed", 403, worker=worker, allowed_workers=ALLOWED_WORKERS)
    if cmd not in ALLOWED_CMDS:
        return err("cmd_not_allowed", 403, cmd=cmd, allowed_cmds=ALLOWED_CMDS)
    return None


def _call_m5_exec(url: str, token: str, subcmd: str) -> Dict[str, Any]:
    r = requests.post(
        f"{url}/exec",
        headers={"Content-Type": "application/json", "x-exec-token": token},
        json={"cmd": subcmd},
        timeout=HTTP_TIMEOUT_SEC,
    )
    try:
        return r.json()
    except Exception:
        return {"ok": False, "error": "non_json", "status": r.status_code, "text": (r.text or "")[:400]}


def _parse_int(s: Any) -> int:
    try:
        return int(str(s).strip())
    except Exception:
        return -1


def _pick_worker(min_vram_mb: int) -> Dict[str, Any]:
    """
    Decide between m5_exec and m5_watch using only vram_mb for now.
    Later we can add util/temperature/power into this function.
    """
    if not (M5_EXEC_URL and M5_EXEC_TOKEN and M5_WATCH_URL and M5_WATCH_TOKEN):
        return {"ok": False, "error": "m5_env_missing"}

    exec_vram_raw = _call_m5_exec(M5_EXEC_URL, M5_EXEC_TOKEN, "vram_mb").get("stdout", "")
    watch_vram_raw = _call_m5_exec(M5_WATCH_URL, M5_WATCH_TOKEN, "vram_mb").get("stdout", "")

    exec_free = _parse_int(exec_vram_raw)
    watch_free = _parse_int(watch_vram_raw)

    # rule: if exec has enough free VRAM, pick exec; else pick watch
    if exec_free >= min_vram_mb:
        chosen = "m5_exec"
        reason = f"Picked m5_exec because {exec_free}MB free >= {min_vram_mb}MB threshold (util not implemented yet)"
    else:
        chosen = "m5_watch"
        reason = f"Picked m5_watch because exec {exec_free}MB free < {min_vram_mb}MB threshold (util not implemented yet)"

    return {
        "ok": True,
        "chosen_worker": chosen,
        "reason": reason,
        "min_vram_mb": min_vram_mb,
        "vram_mb": {"m5_exec": exec_free, "m5_watch": watch_free},
    }


async def _do_worker_exec(body: Dict[str, Any]) -> JSONResponse:
    """
    Shared implementation for /tool/exec and /worker/exec.
    """
    worker = (body.get("worker") or "").strip()
    cmd = (body.get("cmd") or "").strip()
    token_override = body.get("token_override", None)

    if not worker or not cmd:
        return err("worker_and_cmd_required", 400)

    denied = _enforce_allowlists(worker, cmd)
    if denied:
        return denied

    # Meta command: return combined M-5 GPU status in one call
    if cmd == "gpu_status":
        if not (M5_EXEC_URL and M5_EXEC_TOKEN and M5_WATCH_URL and M5_WATCH_TOKEN):
            return err("m5_env_missing_for_gpu_status", 500)

        exec_probe = _call_m5_exec(M5_EXEC_URL, M5_EXEC_TOKEN, "cuda_probe")
        exec_vram = _call_m5_exec(M5_EXEC_URL, M5_EXEC_TOKEN, "vram_mb")
        watch_probe = _call_m5_exec(M5_WATCH_URL, M5_WATCH_TOKEN, "cuda_probe")
        watch_vram = _call_m5_exec(M5_WATCH_URL, M5_WATCH_TOKEN, "vram_mb")

        return ok(
            {
                "ok": True,
                "ts": int(time.time()),
                "m5_exec": {"cuda_probe": exec_probe.get("stdout"), "vram_mb": exec_vram.get("stdout")},
                "m5_watch": {"cuda_probe": watch_probe.get("stdout"), "vram_mb": watch_vram.get("stdout")},
            }
        )

    # Meta command: pick worker + reason (no execution)
    if cmd == "auto_pick_worker":
        args = body.get("args") or {}
        min_vram = _parse_int(args.get("min_vram_mb") or AUTO_PICK_MIN_VRAM_MB)

        pick = _pick_worker(min_vram)
        if not pick.get("ok"):
            return err("auto_pick_failed", 500, detail=pick)

        return ok({"ok": True, "ts": int(time.time()), **pick})

    # Meta command: choose exec vs watch based on free VRAM and run a sub-command
    # Request format:
    #   {"worker":"m5_exec","cmd":"auto_exec","args":{"subcmd":"cuda_probe","min_vram_mb":7000}}
    if cmd == "auto_exec":
        args = body.get("args") or {}
        subcmd = (args.get("subcmd") or "").strip()
        min_vram = _parse_int(args.get("min_vram_mb") or AUTO_EXEC_MIN_VRAM_MB)

        if not subcmd:
            return err("auto_exec_subcmd_required", 400, hint="include args.subcmd")

        pick = _pick_worker(min_vram)
        if not pick.get("ok"):
            return err("auto_exec_pick_failed", 500, detail=pick)

        chosen = pick["chosen_worker"]
        chosen_url = M5_EXEC_URL if chosen == "m5_exec" else M5_WATCH_URL
        chosen_token = M5_EXEC_TOKEN if chosen == "m5_exec" else M5_WATCH_TOKEN

        # allow emergency override token if provided
        token_to_use = (token_override or chosen_token)

        result = _call_m5_exec(chosen_url, token_to_use, subcmd)

        return ok(
            {
                "ok": True,
                "ts": int(time.time()),
                "chosen_worker": chosen,
                "reason": pick["reason"],
                "min_vram_mb": min_vram,
                "vram_mb": pick["vram_mb"],
                "subcmd": subcmd,
                "result": result,
            }
        )

    # Direct routing for M-5 workers (muscle node)
    if worker in ("m5_exec", "m5_watch"):
        target_url = M5_EXEC_URL if worker == "m5_exec" else M5_WATCH_URL
        target_token = M5_EXEC_TOKEN if worker == "m5_exec" else M5_WATCH_TOKEN

        if not target_url:
            return err("m5_target_url_missing", 500, worker=worker)
        if not (token_override or target_token):
            return err("m5_token_missing", 500, worker=worker)

        try:
            r = requests.post(
                f"{target_url}/exec",
                headers={
                    "Content-Type": "application/json",
                    "x-exec-token": (token_override or target_token),
                },
                json={"cmd": cmd},
                timeout=HTTP_TIMEOUT_SEC,
            )
        except Exception as e:
            return err("m5_unreachable", 502, worker=worker, detail=str(e), url=target_url)

        try:
            data = r.json()
        except Exception:
            return err(
                "non_json_response_from_m5",
                502,
                worker=worker,
                status=r.status_code,
                text=(r.text or "")[:1000],
            )

        return JSONResponse(data, status_code=r.status_code)

    # Default behavior: forward to spotd
    try:
        r = requests.post(
            f"{SPOTD_URL}/worker/exec",
            json={"worker": worker, "cmd": cmd, "token_override": token_override},
            timeout=HTTP_TIMEOUT_SEC,
        )
    except Exception as e:
        return err("spotd_unreachable", 502, detail=str(e), spotd_url=SPOTD_URL)

    try:
        data = r.json()
    except Exception:
        return err(
            "non_json_response_from_spotd",
            502,
            status=r.status_code,
            text=(r.text or "")[:1000],
        )

    return JSONResponse(data, status_code=r.status_code)


@APP.post("/tool/exec")
async def tool_exec(req: Request):
    """
    Preferred endpoint for OS building / LCARS panel.
    Safe allowlisted wrapper around spotd /worker/exec OR direct M-5 routing OR meta commands.
    """
    body = await req.json()
    return await _do_worker_exec(body)


@APP.post("/worker/exec")
async def worker_exec(req: Request):
    """
    Backward-compatible alias for older clients.
    """
    body = await req.json()
    return await _do_worker_exec(body)
