import os
import subprocess
import time
from typing import Any, Dict, Optional

from fastapi import FastAPI, HTTPException, Request
from fastapi.responses import JSONResponse

APP = FastAPI(title="spot-worker6")

START = time.time()
EXEC_TOKEN = os.environ.get("EXEC_TOKEN", "changeme6").strip()

def _run(cmd: list[str], timeout: int = 30) -> Dict[str, Any]:
    p = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
    return {"rc": p.returncode, "stdout": p.stdout or "", "stderr": p.stderr or ""}

def _auth(req: Request) -> None:
    tok = (req.headers.get("x-exec-token") or "").strip()
    if not tok or tok != EXEC_TOKEN:
        raise HTTPException(status_code=401, detail="bad_token")

def vram_mb() -> Dict[str, Any]:
    """
    Returns free VRAM for the *visible* GPU.
    Because CUDA_VISIBLE_DEVICES is set via systemd drop-in,
    the visible GPU should appear as index 0 to nvidia-smi.
    """
    # free memory in MiB for visible GPU 0
    r = _run(["bash", "-lc", "nvidia-smi --query-gpu=memory.free --format=csv,noheader,nounits -i 0"])
    if r["rc"] != 0:
        return r
    # normalize to single int line
    line = (r["stdout"].strip().splitlines()[0] if r["stdout"].strip() else "").strip()
    return {"rc": 0, "stdout": f"{line}\n", "stderr": ""}

def cuda_probe() -> Dict[str, Any]:
    # Runs a tiny torch probe inside the venv
    py = os.path.join(os.path.dirname(__file__), ".venv", "bin", "python3")
    code = r"""
import os, torch
print("PY=", __import__("sys").executable)
print("CUDA_VISIBLE_DEVICES=", os.environ.get("CUDA_VISIBLE_DEVICES",""))
print("torch_version", torch.__version__)
print("torch_cuda_available", torch.cuda.is_available())
print("gpu_count", torch.cuda.device_count())
if torch.cuda.is_available() and torch.cuda.device_count():
    print("gpu_name", torch.cuda.get_device_name(0))
"""
    r = _run([py, "-c", code], timeout=60)
    return r

def gpu_map() -> Dict[str, Any]:
    # shows visible GPU(s) list
    r = _run(["bash", "-lc", "nvidia-smi --query-gpu=index,name,pci.bus_id,memory.total,memory.free --format=csv,noheader"])
    return r


ALLOWED = {
    "cuda_probe": None,
    "vram_mb": None,
    "gpu_map": None,
    "gpu_util": None,
}

@APP.get("/health")
def health():
    return {"ok": True, "role": "worker6", "uptime_sec": int(time.time() - START)}

@APP.post("/exec")
async def exec_(req: Request):
    _auth(req)
    body = await req.json()
    cmd = (body.get("cmd") or "").strip()
    if cmd not in ALLOWED:
        raise HTTPException(status_code=400, detail="cmd_not_allowed")

    if cmd == "cuda_probe":
        out = cuda_probe()
        return {"ok": True, **out}
    if cmd == "vram_mb":
        out = vram_mb()
        return {"ok": True, **out}
    if cmd == "gpu_map":
        out = gpu_map()
        return {"ok": True, **out}
    if cmd == "gpu_util":
        out = gpu_util()
        return {"ok": True, **out}

    return JSONResponse({"ok": False, "error": "unhandled"}, status_code=500)
