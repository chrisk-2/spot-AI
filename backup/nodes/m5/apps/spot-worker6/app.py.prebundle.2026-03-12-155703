import sys
import os
import time
import json
import uuid
import subprocess
import traceback
from pathlib import Path
from typing import Dict, Any, Optional

from fastapi import FastAPI, Request
from fastapi.responses import JSONResponse
from fastapi import HTTPException

APP = FastAPI(title="Spot Worker 6")

EXEC_TOKEN = os.environ.get("EXEC_TOKEN", "changeme6")
START = time.time()

# Job runner config
JOB_DIR = Path(os.environ.get("JOB_DIR", "/mnt/collective/jobs"))
JOB_OUT_DIR = Path(os.environ.get("JOB_OUT_DIR", "/mnt/collective/jobs_out"))
ALLOWED_JOBS = [x.strip() for x in os.environ.get("ALLOWED_JOBS", "example_echo,example_sleep,llm_infer,llm_infer_stream").split(",") if x.strip()]
DEFAULT_JOB_TIMEOUT_SEC = int(os.environ.get("JOB_TIMEOUT_SEC", "900"))


@APP.exception_handler(Exception)
async def all_exception_handler(request: Request, exc: Exception):
    return JSONResponse(
        status_code=500,
        content={
            "ok": False,
            "error": "internal_error",
            "exc": repr(exc),
            "traceback": traceback.format_exc(),
        },
    )


def _auth(req: Request):
    token = req.headers.get("x-exec-token")
    if token != EXEC_TOKEN:
        raise HTTPException(status_code=401, detail="unauthorized")


def _run(cmd, timeout: int = 60) -> Dict[str, Any]:
    try:
        p = subprocess.run(cmd, capture_output=True, text=True, timeout=timeout)
        return {"ok": True, "rc": p.returncode, "stdout": p.stdout, "stderr": p.stderr}
    except subprocess.TimeoutExpired as e:
        return {"ok": False, "error": "timeout", "rc": 124, "stdout": (e.stdout or ""), "stderr": (e.stderr or "")}


def _first_int(s: str) -> int:
    s = (s or "").strip()
    digits = "".join(ch for ch in s if ch.isdigit())
    return int(digits) if digits else -1


def _parse_gpu_util(stdout: str) -> Dict[str, Any]:
    line = (stdout or "").strip().splitlines()[0] if (stdout or "").strip() else ""
    parts = [p.strip() for p in line.split(",")] if line else []
    out: Dict[str, Any] = {"raw": line}
    if len(parts) >= 5:
        out["index"] = parts[0]
        out["util_gpu"] = parts[1]
        out["util_mem"] = parts[2]
        out["temp_c"] = parts[3]
        out["power_w"] = parts[4]
    return out


def _parse_torch_version(stdout: str) -> str:
    for line in (stdout or "").splitlines():
        if line.startswith("torch_version"):
            return line.split(" ", 1)[1].strip() if " " in line else line.strip()
    return ""


def cuda_probe() -> Dict[str, Any]:
    py = sys.executable
    code = r"""
import os
import sys
import torch

print("PY=", sys.executable)
print("CUDA_VISIBLE_DEVICES=", os.environ.get("CUDA_VISIBLE_DEVICES",""))
print("torch_version", torch.__version__)
print("torch_cuda_available", torch.cuda.is_available())
print("gpu_count", torch.cuda.device_count())
if torch.cuda.device_count() > 0:
    print("gpu_name", torch.cuda.get_device_name(0))
"""
    return _run([py, "-c", code], timeout=60)


def vram_mb() -> Dict[str, Any]:
    cmd = r'''
IDX="${CUDA_VISIBLE_DEVICES:-0}"
IDX="${IDX%%,*}"
nvidia-smi -i "$IDX" --query-gpu=memory.free --format=csv,noheader,nounits
'''
    return _run(["bash", "-lc", cmd], timeout=20)


def vram_free_mb():
    r = _run(
        ["bash", "-lc", 'nvidia-smi -i "${CUDA_VISIBLE_DEVICES:-0}" --query-gpu=memory.free --format=csv,noheader,nounits'],
        timeout=20,
    )
    return {"rc": r.get("rc", 1), "stdout": r.get("stdout", ""), "stderr": r.get("stderr", "")}


def gpu_map() -> Dict[str, Any]:
    return _run(
        ["bash", "-lc", "nvidia-smi --query-gpu=index,name,pci.bus_id,memory.total,memory.free --format=csv,noheader"],
        timeout=20,
    )


