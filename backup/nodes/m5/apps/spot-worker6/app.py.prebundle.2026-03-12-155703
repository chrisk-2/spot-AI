IDX="${IDX%%,*}"
nvidia-smi -i "$IDX" \
--query-gpu=index,utilization.gpu,utilization.memory,temperature.gpu,power.draw \
--format=csv,noheader
'''
    return _run(["bash", "-lc", cmd], timeout=20)


def gpu_id() -> Dict[str, Any]:
    cmd = r'''
IDX="${CUDA_VISIBLE_DEVICES:-0}"
IDX="${IDX%%,*}"
nvidia-smi -i "$IDX" --query-gpu=index,name,pci.bus_id --format=csv,noheader
'''
    return _run(["bash", "-lc", cmd], timeout=20)


def _safe_job_name(name: str) -> str:
    name = (name or "").strip()
    if not name:
        raise ValueError("missing_job")
    for ch in name:
        if not (ch.isalnum() or ch in ("_", "-")):
            raise ValueError("bad_job_name")
    return name


def _job_script_path(job: str) -> Path:
    sh = JOB_DIR / f"{job}.sh"
    py = JOB_DIR / f"{job}.py"
    direct = JOB_DIR / job
    if sh.exists():
        return sh
    if py.exists():
        return py
    if direct.exists():
        return direct
    raise FileNotFoundError("job_not_found")


def run_job(args: Dict[str, Any]) -> Dict[str, Any]:
    try:
        job = _safe_job_name(args.get("job", ""))
    except Exception as e:
        return {"ok": False, "error": "bad_job", "detail": repr(e)}

    if job not in ALLOWED_JOBS:
        return {"ok": False, "error": "job_not_allowed", "job": job, "allowed_jobs": ALLOWED_JOBS}

    timeout_sec = int(args.get("timeout_sec") or DEFAULT_JOB_TIMEOUT_SEC)
    params = args.get("params") or {}
    if not isinstance(params, dict):
        return {"ok": False, "error": "params_must_be_object"}

    script = _job_script_path(job)

    job_id = uuid.uuid4().hex[:12]
    out_dir = JOB_OUT_DIR / job / job_id
    out_dir.mkdir(parents=True, exist_ok=True)

    (out_dir / "params.json").write_text(json.dumps(params, indent=2, sort_keys=True))

    env = os.environ.copy()
    env["JOB_ID"] = job_id
    env["JOB_NAME"] = job
    env["JOB_OUT_DIR"] = str(out_dir)
    for k, v in params.items():
        kk = str(k).upper().replace(" ", "_")
        env[f"JOB_PARAM_{kk}"] = str(v)

    if script.suffix == ".py":
        argv = [sys.executable, str(script)]
    elif script.suffix == ".sh":
        argv = ["bash", str(script)]
    else:
        argv = [str(script)]

    try:
        p = subprocess.run(
            argv,
            cwd=str(JOB_DIR),
            env=env,
            text=True,
            capture_output=True,
            timeout=timeout_sec,
        )
        (out_dir / "stdout.txt").write_text(p.stdout or "")
        (out_dir / "stderr.txt").write_text(p.stderr or "")
        (out_dir / "rc.txt").write_text(str(p.returncode))
        return {
            "ok": True,
            "job": job,
            "job_id": job_id,
            "script": str(script),
            "timeout_sec": timeout_sec,
            "rc": p.returncode,
            "out_dir": str(out_dir),
        }
    except subprocess.TimeoutExpired as e:
        (out_dir / "stdout.txt").write_text(e.stdout or "")
        (out_dir / "stderr.txt").write_text((e.stderr or "") + "\nTIMEOUT")
        (out_dir / "rc.txt").write_text("124")
        return {
            "ok": False,
            "error": "timeout",
            "job": job,
            "job_id": job_id,
            "script": str(script),
            "timeout_sec": timeout_sec,
            "rc": 124,
            "out_dir": str(out_dir),
        }
    except Exception as e:
        (out_dir / "stderr.txt").write_text(repr(e))
        (out_dir / "rc.txt").write_text("1")
        return {"ok": False, "error": "job_failed", "job": job, "job_id": job_id, "rc": 1, "out_dir": str(out_dir), "exc": repr(e)}


ALLOWED = {
    "cuda_probe": cuda_probe,
    "vram_mb": vram_mb,
    "gpu_map": gpu_map,
    "gpu_util": gpu_util,
    "gpu_id": gpu_id,
    "vram_free_mb": vram_free_mb,
    "run_job": run_job,
}


@APP.get("/health")
def health():
    return {"ok": True, "role": "worker6", "uptime_sec": int(time.time() - START)}


@APP.get("/status")
def status():
    uptime = int(time.time() - START)
    gid = gpu_id()
    vram = vram_mb()
    util = gpu_util()
    probe = cuda_probe()
    vram_free = _first_int(vram.get("stdout", ""))

    return {
        "ok": True,
        "role": "worker6",
        "uptime_sec": uptime,
        "gpu_id": (gid.get("stdout") or "").strip(),
        "vram_free_mb": vram_free,
        "gpu_util": _parse_gpu_util(util.get("stdout", "")),
        "torch_version": _parse_torch_version(probe.get("stdout", "")),
        "cuda_probe_ok": bool("torch_cuda_available True" in (probe.get("stdout") or "")),
        "job_dir": str(JOB_DIR),
        "job_out_dir": str(JOB_OUT_DIR),
        "allowed_jobs": ALLOWED_JOBS,
    }


@APP.post("/exec")
async def exec_(req: Request):
    _auth(req)
    try:
        body = await req.json()
    except Exception:
        return {"ok": False, "error": "bad_json"}

    cmd = (body.get("cmd") or "").strip()
    if cmd not in ALLOWED:
        return {"ok": False, "error": "cmd_not_allowed", "cmd": cmd, "allowed_cmds": sorted(ALLOWED.keys())}

    if cmd == "run_job":
        args = body.get("args") or {}
        if not isinstance(args, dict):
            return {"ok": False, "error": "args_must_be_object"}
        return ALLOWED[cmd](args)

    return ALLOWED[cmd]()
